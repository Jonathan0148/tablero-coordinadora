      "name": "Auth",
      "item": [
        {
          "name": "Auth - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const response = pm.response.json();",
                  "pm.test('Enterprise response wrapper exists', function () { pm.expect(response).to.include.keys(['code', 'message', 'userMessage', 'data']); });",
                  "const json = response.data;",
                  "const token = json.accessToken || json.access_token;",
                  "const refresh = json.refreshToken || json.refresh_token || '';",
                  "pm.test('Access token exists', function () { pm.expect(token).to.be.a('string').and.not.empty; });",
                  "pm.environment.set('jwtToken', token);",
                  "if (refresh) { pm.environment.set('refreshToken', refresh); }",
                  "pm.test('User profile exists', function () { pm.expect(json.user).to.be.an('object'); });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
